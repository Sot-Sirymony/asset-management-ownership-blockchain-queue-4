# Environment Variables Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
# For local Maven run:
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:55432/asset_holder_db
# For API-in-Docker, use:
# SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/asset_holder_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here
POSTGRES_DB=asset_holder_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=55432
API_HOST_PORT=18081

# Hyperledger Fabric Configuration
FABRIC_CHAINCODE=basic
FABRIC_CHANNEL=mychannel
COUCHDB_BASE_URL=http://couchdb0:5984
COUCHDB_USER=admin
COUCHDB_PASS=password
NETWORK_CRYPTO_PATH=../ownership-network-master/channel/crypto-config
NETWORK_CONNECTION_PROFILE=../ownership-network-master/connection-profile/connection.yaml

# Windows: set one of these so the API can find the Fabric CA TLS certificate (avoids E:\etc\... path error).
# Option A - set FABRIC_CRYPTO_PATH to the channel directory (resolver will find ca.crt under it):
# FABRIC_CRYPTO_PATH=E:\path\to\All In One Source\ownership-network-master\channel
# Option B - set full path to the CA cert file:
# FABRIC_CA_PEM_FILE=E:\path\to\All In One Source\ownership-network-master\channel\crypto-config\peerOrganizations\org1.ownify.com\users\Admin@org1.ownify.com\tls\ca.crt
# Optional: wallet directory (default: ownership-api-master/wallet)
# WALLET_PATH=E:\path\to\All In One Source\ownership-api-master\wallet

# Application Configuration
SERVER_PORT=8081
